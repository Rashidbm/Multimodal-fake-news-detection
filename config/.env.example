# MultiGuard Environment Variables
# Copy this file to .env and fill in your API keys
# =================================================

# =============================================================================
# NEWS API KEYS (Optional - RSS feeds work without these)
# =============================================================================

# GNews API - Get free key at: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# NewsAPI.org - Get free key at: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# =============================================================================
# AI GENERATION API KEYS
# =============================================================================

# Google Gemini API - Get free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Stability AI API - Get key at: https://platform.stability.ai/
STABILITY_API_KEY=your_stability_api_key_here

# OpenAI API (alternative) - Get key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/disable specific features
ENABLE_IMAGE_GENERATION=false
ENABLE_TEXT_GENERATION=false
